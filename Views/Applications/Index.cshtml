@model IEnumerable<InternHub.Models.Application>
@using InternHub.Models
@{
    ViewData["Title"] = "Applications";
    var search       = ViewData["CurrentSearch"] as string;
    var currentStatus = ViewData["CurrentStatus"] as string;
    var statusList   = ViewData["StatusList"] as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
}

@functions {
    string GetStatusClass(string s) => s switch {
        "Applied"             => "badge-applied",
        "OAScheduled"         => "badge-oa-scheduled",
        "OACompleted"         => "badge-oa-completed",
        "InterviewScheduled"  => "badge-interview-scheduled",
        "Rejected"            => "badge-rejected",
        "Selected"            => "badge-selected",
        _                     => ""
    };
    string FriendlyStatus(string s) => s switch {
        "OAScheduled"        => "OA Scheduled",
        "OACompleted"        => "OA Completed",
        "InterviewScheduled" => "Interview Scheduled",
        _ => s
    };
}

<div class="container-fluid px-4">
    <div class="page-header mb-4" style="background:none; border:none; padding:1.5rem 0 0;">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h1><i class="bi bi-file-earmark-text me-2"></i>Applications</h1>
                <p>Track all your internship applications and their current status.</p>
            </div>
            <a asp-action="Create" class="btn-primary-custom">
                <i class="bi bi-plus-circle-fill"></i> Add Application
            </a>
        </div>
    </div>

    <div class="data-card mb-4">
        <div class="data-card-header flex-wrap gap-2">
            <h5><i class="bi bi-list-ul me-2"></i>All Applications</h5>
            <!-- Search + Filter Form -->
            <form method="get" asp-action="Index" class="d-flex flex-wrap gap-2 align-items-center">
                <div class="search-bar">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" class="form-control"
                           placeholder="Search role or company..." value="@search"
                           style="min-width:200px;" />
                </div>
                <select name="statusFilter" class="form-select" style="width:auto;">
                    <option value="">All Statuses</option>
                    @foreach (var item in statusList ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                    {
                        <option value="@item.Value" selected="@(item.Value == currentStatus)">
                            @FriendlyStatus(item.Text)
                        </option>
                    }
                </select>
                <button type="submit" class="btn-primary-custom" style="padding:8px 16px;">Filter</button>
                @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(currentStatus))
                {
                    <a asp-action="Index" class="btn-outline-custom" style="padding:8px 14px;">Clear</a>
                }
            </form>
        </div>

        <div class="data-card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5" style="color:var(--text-muted);">
                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                    No applications found. <a asp-action="Create">Add one!</a>
                </div>
            }
            else
            {
                <table class="table-dark-custom w-100">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Company</th>
                            <th>Role</th>
                            <th>Stipend</th>
                            <th>Applied</th>
                            <th>Deadline</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var app in Model)
                        {
                            bool isDeadlineClose = app.Deadline.HasValue && app.Deadline.Value.Date <= DateTime.Now.Date.AddDays(3) && app.Deadline.Value.Date >= DateTime.Now.Date;
                            <tr>
                                <td style="color:var(--text-muted);">@i++</td>
                                <td><strong>@app.Company?.Name</strong></td>
                                <td style="color:var(--text-muted);">@app.Role</td>
                                <td>
                                    @if (app.Stipend.HasValue)
                                    {
                                        <span style="color:var(--success);">₹@app.Stipend.Value.ToString("N0")</span>
                                    }
                                    else { <span style="color:var(--text-muted);">—</span> }
                                </td>
                                <td style="font-size:0.82rem; color:var(--text-muted);">@app.ApplicationDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (app.Deadline.HasValue)
                                    {
                                        <span style="font-size:0.82rem; @(isDeadlineClose ? "color:var(--warning);font-weight:600;" : "color:var(--text-muted);")">
                                            @app.Deadline.Value.ToString("dd MMM yyyy")
                                            @if (isDeadlineClose)
                                            {
                                                <i class="bi bi-exclamation-triangle-fill ms-1"></i>
                                            }
                                        </span>
                                    }
                                    else { <span style="color:var(--text-muted);">—</span> }
                                </td>
                                <td>
                                    <span class="badge-status @GetStatusClass(app.Status.ToString())">
                                        @FriendlyStatus(app.Status.ToString())
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@app.Id" class="action-btn view" title="View"><i class="bi bi-eye-fill"></i></a>
                                        <a asp-action="Edit"    asp-route-id="@app.Id" class="action-btn edit" title="Edit"><i class="bi bi-pencil-fill"></i></a>
                                        <a asp-action="Delete"  asp-route-id="@app.Id" class="action-btn delete" title="Delete"><i class="bi bi-trash-fill"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
