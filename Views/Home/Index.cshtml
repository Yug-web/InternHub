@model InternHub.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-4">

    <!-- Page Header -->
    <div class="page-header">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h1><i class="bi bi-speedometer2"></i>Dashboard</h1>
                <p>Welcome back! Here's your internship application overview.</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Applications" asp-action="Create" class="btn-primary-custom">
                    <i class="bi bi-plus-lg"></i> New Application
                </a>
                <a asp-controller="Deadlines" asp-action="Create" class="btn-outline-custom">
                    <i class="bi bi-clock-history"></i> Add Deadline
                </a>
            </div>
        </div>
    </div>

    <!-- ── Stat Cards Row 1 ──────────────────────────────────────────────── -->
    <div class="row g-3 mb-3">

        <div class="col-6 col-md-4 col-xl-2">
            <div class="stat-card" style="--stat-color: #6366f1;">
                <div class="stat-icon"><i class="bi bi-file-earmark-text-fill"></i></div>
                <div class="stat-body">
                    <div class="stat-value" data-target="@Model.TotalApplications">0</div>
                    <div class="stat-label">Total Applied</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-xl-2">
            <div class="stat-card" style="--stat-color: #3b82f6;">
                <div class="stat-icon"><i class="bi bi-send-fill"></i></div>
                <div class="stat-body">
                    <div class="stat-value" data-target="@Model.AppliedCount">0</div>
                    <div class="stat-label">Applied</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-xl-2">
            <div class="stat-card" style="--stat-color: #8b5cf6;">
                <div class="stat-icon"><i class="bi bi-camera-video-fill"></i></div>
                <div class="stat-body">
                    <div class="stat-value" data-target="@Model.InterviewScheduledCount">0</div>
                    <div class="stat-label">Interviews</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-xl-2">
            <div class="stat-card" style="--stat-color: #10b981;">
                <div class="stat-icon"><i class="bi bi-trophy-fill"></i></div>
                <div class="stat-body">
                    <div class="stat-value" data-target="@Model.SelectedCount">0</div>
                    <div class="stat-label">Selected</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-xl-2">
            <div class="stat-card" style="--stat-color: #ef4444;">
                <div class="stat-icon"><i class="bi bi-x-circle-fill"></i></div>
                <div class="stat-body">
                    <div class="stat-value" data-target="@Model.RejectedCount">0</div>
                    <div class="stat-label">Rejected</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-xl-2">
            <div class="stat-card" style="--stat-color: #06b6d4;">
                <div class="stat-icon"><i class="bi bi-building"></i></div>
                <div class="stat-body">
                    <div class="stat-value" data-target="@Model.TotalCompanies">0</div>
                    <div class="stat-label">Companies</div>
                </div>
            </div>
        </div>

    </div>

    <!-- ── Stat Cards Row 2 (computed stats) ────────────────────────────── -->
    <div class="row g-3 mb-4">

        <div class="col-6 col-md-3">
            <div class="stat-card" style="--stat-color: #f59e0b;">
                <div class="stat-icon"><i class="bi bi-activity"></i></div>
                <div class="stat-body">
                    <div class="stat-value" data-target="@Model.ActiveCount">0</div>
                    <div class="stat-label">Active Apps</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="stat-card" style="--stat-color: #10b981;">
                <div class="stat-icon"><i class="bi bi-percent"></i></div>
                <div class="stat-body">
                    <div class="stat-value">@Model.SuccessRate<span style="font-size:1rem;">%</span></div>
                    <div class="stat-label">Success Rate</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="stat-card" style="--stat-color: #8b5cf6;">
                <div class="stat-icon"><i class="bi bi-camera-video"></i></div>
                <div class="stat-body">
                    <div class="stat-value" data-target="@Model.TotalInterviews">0</div>
                    <div class="stat-label">All Interviews</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="stat-card" style="--stat-color: #ef4444;">
                <div class="stat-icon"><i class="bi bi-clock-history"></i></div>
                <div class="stat-body">
                    <div class="stat-value" data-target="@Model.UpcomingDeadlinesCount">0</div>
                    <div class="stat-label">Upcoming Deadlines</div>
                </div>
            </div>
        </div>

    </div>

    <!-- ── Main Content Row ──────────────────────────────────────────────── -->
    <div class="row g-4">

        <!-- Recent Applications -->
        <div class="col-12 col-xl-7">
            <div class="data-card h-100">
                <div class="data-card-header">
                    <h5><i class="bi bi-file-earmark-text"></i>Recent Applications</h5>
                    <a asp-controller="Applications" asp-action="Index" class="btn-outline-custom" style="padding:5px 12px; font-size:0.8rem;">
                        View All <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="data-card-body">
                    @if (!Model.RecentApplications.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-file-earmark-plus"></i>
                            <p>No applications yet.</p>
                            <a asp-controller="Applications" asp-action="Create" class="btn-primary-custom" style="font-size:0.8rem; padding:6px 14px;">
                                <i class="bi bi-plus-lg"></i> Add First Application
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table-dark-custom w-100">
                                <thead>
                                    <tr>
                                        <th>Company</th>
                                        <th>Role</th>
                                        <th>Status</th>
                                        <th>Applied</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var app in Model.RecentApplications)
                                    {
                                        var statusClass = app.Status.ToString().ToLower();
                                        <tr>
                                            <td><strong>@app.Company?.Name</strong></td>
                                            <td style="color:var(--text-muted);">@app.Role</td>
                                            <td>
                                                <span class="badge-status badge-@statusClass">
                                                    @app.Status
                                                </span>
                                            </td>
                                            <td style="color:var(--text-muted); font-size:0.8rem;">
                                                @app.ApplicationDate.ToString("dd MMM yy")
                                            </td>
                                            <td>
                                                <a asp-controller="Applications" asp-action="Details" asp-route-id="@app.Id" class="action-btn view" title="View">
                                                    <i class="bi bi-eye-fill"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-12 col-xl-5">

            <!-- Upcoming Deadlines -->
            <div class="data-card mb-4">
                <div class="data-card-header">
                    <h5><i class="bi bi-clock-history"></i>Upcoming Deadlines</h5>
                    <a asp-controller="Deadlines" asp-action="Index" class="btn-outline-custom" style="padding:5px 12px; font-size:0.8rem;">
                        View All <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="data-card-body">
                    @if (!Model.UpcomingDeadlines.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-calendar-check"></i>
                            <p>No upcoming deadlines.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table-dark-custom w-100">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Due</th>
                                        <th>Priority</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var dl in Model.UpcomingDeadlines)
                                    {
                                        int daysLeft = (dl.DueDate.Date - DateTime.Now.Date).Days;
                                        bool isUrgent = daysLeft <= 3;
                                        <tr>
                                            <td style="max-width:160px;">
                                                <div style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="@dl.Title">
                                                    @dl.Title
                                                </div>
                                            </td>
                                            <td>
                                                <span style="font-size:0.8rem; color:@(isUrgent ? "var(--warning)" : "var(--text-muted)");">
                                                    @(daysLeft == 0 ? "TODAY" : daysLeft + "d left")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge-status badge-@dl.Priority.ToString().ToLower()">@dl.Priority</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Recent Interviews -->
            <div class="data-card">
                <div class="data-card-header">
                    <h5><i class="bi bi-camera-video"></i>Recent Interviews</h5>
                    <a asp-controller="Interviews" asp-action="Index" class="btn-outline-custom" style="padding:5px 12px; font-size:0.8rem;">
                        View All <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="data-card-body">
                    @if (!Model.RecentInterviews.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-camera-video-off"></i>
                            <p>No interviews logged yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table-dark-custom w-100">
                                <thead>
                                    <tr>
                                        <th>Company</th>
                                        <th>Type</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var iv in Model.RecentInterviews)
                                    {
                                        <tr>
                                            <td><strong>@iv.Company?.Name</strong></td>
                                            <td>
                                                <span class="badge-status badge-@iv.InterviewType.ToString().ToLower()">
                                                    @iv.InterviewType
                                                </span>
                                            </td>
                                            <td style="color:var(--text-muted); font-size:0.8rem;">
                                                @iv.InterviewDate.ToString("dd MMM yy")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ── Quick Action Links ────────────────────────────────────────────── -->
    <div class="row g-3 mt-2">
        <div class="col-12">
            <div class="data-card">
                <div class="data-card-body p-3">
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <span style="font-size:0.78rem; color:var(--text-muted); font-weight:600; text-transform:uppercase; letter-spacing:0.5px; margin-right:4px;">
                            Quick Actions:
                        </span>
                        <a asp-controller="Companies"    asp-action="Create" class="btn-outline-custom" style="padding:6px 14px; font-size:0.82rem;"><i class="bi bi-building-add"></i> Add Company</a>
                        <a asp-controller="Applications" asp-action="Create" class="btn-outline-custom" style="padding:6px 14px; font-size:0.82rem;"><i class="bi bi-file-earmark-plus"></i> Add Application</a>
                        <a asp-controller="Interviews"   asp-action="Create" class="btn-outline-custom" style="padding:6px 14px; font-size:0.82rem;"><i class="bi bi-camera-video-fill"></i> Log Interview</a>
                        <a asp-controller="Deadlines"    asp-action="Create" class="btn-outline-custom" style="padding:6px 14px; font-size:0.82rem;"><i class="bi bi-calendar-plus"></i> Add Deadline</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
