@model IEnumerable<InternHub.Models.Interview>
@{
    ViewData["Title"] = "Interviews";
    var currentType = ViewData["CurrentType"] as string;
    var typeList    = ViewData["TypeList"] as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
}

<div class="container-fluid px-4">
    <div class="page-header mb-4" style="background:none; border:none; padding:1.5rem 0 0;">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h1><i class="bi bi-camera-video me-2"></i>Interview Tracker</h1>
                <p>Log and review all your interview rounds.</p>
            </div>
            <a asp-action="Create" class="btn-primary-custom">
                <i class="bi bi-plus-circle-fill"></i> Log Interview
            </a>
        </div>
    </div>

    <div class="data-card mb-4">
        <div class="data-card-header flex-wrap gap-2">
            <h5><i class="bi bi-list-ul me-2"></i>All Interviews</h5>
            <form method="get" asp-action="Index" class="d-flex gap-2 align-items-center">
                <select name="typeFilter" class="form-select" style="width:auto;">
                    <option value="">All Types</option>
                    @foreach (var item in typeList ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                    {
                        <option value="@item.Value" selected="@(item.Value == currentType)">@item.Text</option>
                    }
                </select>
                <button type="submit" class="btn-primary-custom" style="padding:8px 16px;">Filter</button>
                @if (!string.IsNullOrEmpty(currentType))
                {
                    <a asp-action="Index" class="btn-outline-custom" style="padding:8px 14px;">Clear</a>
                }
            </form>
        </div>

        <div class="data-card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5" style="color:var(--text-muted);">
                    <i class="bi bi-camera-video-off fs-2 d-block mb-2"></i>
                    No interviews logged yet. <a asp-action="Create">Add one!</a>
                </div>
            }
            else
            {
                <table class="table-dark-custom w-100">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Company</th>
                            <th>Role</th>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Notes</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var iv in Model)
                        {
                            bool isPast = iv.InterviewDate.Date < DateTime.Now.Date;
                            bool isToday = iv.InterviewDate.Date == DateTime.Now.Date;
                            <tr>
                                <td style="color:var(--text-muted);">@i++</td>
                                <td><strong>@iv.Company?.Name</strong></td>
                                <td style="color:var(--text-muted);">@iv.Role</td>
                                <td>
                                    <span style="font-size:0.85rem; @(isToday ? "color:var(--warning); font-weight:700;" : isPast ? "color:var(--text-muted);" : "color:var(--success);")">
                                        @iv.InterviewDate.ToString("dd MMM yyyy")
                                        @if (isToday) { <span class="ms-1">🔴 TODAY</span> }
                                    </span>
                                </td>
                                <td>
                                    <span class="badge-status badge-@iv.InterviewType.ToString().ToLower()">
                                        @iv.InterviewType
                                    </span>
                                </td>
                                <td style="font-size:0.82rem; color:var(--text-muted); max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                    @iv.Notes
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@iv.Id" class="action-btn view" title="View"><i class="bi bi-eye-fill"></i></a>
                                        <a asp-action="Edit"    asp-route-id="@iv.Id" class="action-btn edit" title="Edit"><i class="bi bi-pencil-fill"></i></a>
                                        <a asp-action="Delete"  asp-route-id="@iv.Id" class="action-btn delete" title="Delete"><i class="bi bi-trash-fill"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
