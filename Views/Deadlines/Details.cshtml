@model InternHub.Models.Deadline
@{
    ViewData["Title"] = "Deadline Details";
    int daysLeft = (Model.DueDate.Date - DateTime.Now.Date).Days;
}

<div class="container-fluid px-4">
    <div class="page-header mb-4" style="background:none; border:none; padding:1.5rem 0 0;">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h1><i class="bi bi-clock-history me-2"></i>Deadline Details</h1>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-outline-custom"><i class="bi bi-pencil-fill"></i> Edit</a>
                <a asp-action="Index" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Back</a>
            </div>
        </div>
    </div>

    <div class="detail-card" style="max-width:600px;">
        <div class="detail-header" style="@(Model.IsOverdue ? "background:linear-gradient(135deg,#7f1d1d,var(--danger));" : "")">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h4 class="mb-1">@Model.Title</h4>
                    <span style="opacity:0.8;">
                        @if (Model.IsOverdue)
                        {
                            <span>⚠️ Overdue by @Math.Abs(daysLeft) day(s)</span>
                        }
                        else if (daysLeft == 0)
                        {
                            <span>🔴 Due TODAY!</span>
                        }
                        else
                        {
                            <span>@daysLeft day(s) remaining</span>
                        }
                    </span>
                </div>
                <span class="badge-status badge-@Model.Priority.ToString().ToLower()">@Model.Priority</span>
            </div>
        </div>
        <div class="detail-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="detail-field">
                        <div class="detail-field-label">Due Date</div>
                        <div class="detail-field-value" style="@(Model.IsOverdue ? "color:var(--danger);" : "")">
                            @Model.DueDate.ToString("dd MMMM yyyy")
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-field">
                        <div class="detail-field-label">Priority</div>
                        <div class="detail-field-value">
                            <span class="badge-status badge-@Model.Priority.ToString().ToLower()">@Model.Priority</span>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="detail-field">
                        <div class="detail-field-label">Description</div>
                        <div class="detail-field-value" style="white-space:pre-line; line-height:1.7;">
                            @(string.IsNullOrEmpty(Model.Description) ? "No description." : Model.Description)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
