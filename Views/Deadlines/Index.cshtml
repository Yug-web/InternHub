@model IEnumerable<InternHub.Models.Deadline>
@{
    ViewData["Title"] = "Deadlines";
    var currentPriority = ViewData["CurrentPriority"] as string;
}

<div class="container-fluid px-4">
    <div class="page-header mb-4" style="background:none; border:none; padding:1.5rem 0 0;">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h1><i class="bi bi-clock-history me-2"></i>Deadline Tracker</h1>
                <p>Never miss an important deadline. Track OA dates, submission deadlines, and more.</p>
            </div>
            <a asp-action="Create" class="btn-primary-custom">
                <i class="bi bi-plus-circle-fill"></i> Add Deadline
            </a>
        </div>
    </div>

    <div class="data-card mb-4">
        <div class="data-card-header flex-wrap gap-2">
            <h5><i class="bi bi-list-ul me-2"></i>All Deadlines</h5>
            <form method="get" asp-action="Index" class="d-flex gap-2 align-items-center">
                <select name="priorityFilter" class="form-select" style="width:auto;">
                    <option value="">All Priorities</option>
                    <option value="High"   selected="@("High"   == currentPriority)">🔴 High</option>
                    <option value="Medium" selected="@("Medium" == currentPriority)">🟡 Medium</option>
                    <option value="Low"    selected="@("Low"    == currentPriority)">🟢 Low</option>
                </select>
                <button type="submit" class="btn-primary-custom" style="padding:8px 16px;">Filter</button>
                @if (!string.IsNullOrEmpty(currentPriority))
                {
                    <a asp-action="Index" class="btn-outline-custom" style="padding:8px 14px;">Clear</a>
                }
            </form>
        </div>

        <div class="data-card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5" style="color:var(--text-muted);">
                    <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>
                    No deadlines found. <a asp-action="Create">Add one!</a>
                </div>
            }
            else
            {
                <table class="table-dark-custom w-100">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>Due Date</th>
                            <th>Days Left</th>
                            <th>Priority</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var dl in Model)
                        {
                            int daysLeft = (dl.DueDate.Date - DateTime.Now.Date).Days;
                            bool isOverdue = dl.IsOverdue;
                            bool isUrgent  = !isOverdue && daysLeft <= 3;
                            <tr class="@(isOverdue ? "row-overdue" : "")">
                                <td style="color:var(--text-muted);">@i++</td>
                                <td><strong>@dl.Title</strong></td>
                                <td>
                                    <span style="font-size:0.85rem; @(isOverdue ? "color:var(--danger);" : isUrgent ? "color:var(--warning);" : "color:var(--text-muted);")">
                                        @dl.DueDate.ToString("dd MMM yyyy")
                                    </span>
                                </td>
                                <td>
                                    @if (isOverdue)
                                    {
                                        <span style="color:var(--danger); font-weight:600; font-size:0.82rem;">
                                            Overdue (@Math.Abs(daysLeft)d ago)
                                        </span>
                                    }
                                    else if (daysLeft == 0)
                                    {
                                        <span style="color:var(--warning); font-weight:700; font-size:0.82rem;">TODAY!</span>
                                    }
                                    else
                                    {
                                        <span style="color:@(isUrgent ? "var(--warning)" : "var(--success)"); font-weight:600; font-size:0.82rem;">
                                            @daysLeft days left
                                        </span>
                                    }
                                </td>
                                <td>
                                    <span class="badge-status badge-@dl.Priority.ToString().ToLower()">
                                        @dl.Priority
                                    </span>
                                </td>
                                <td style="font-size:0.82rem; color:var(--text-muted); max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                    @dl.Description
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@dl.Id" class="action-btn view" title="View"><i class="bi bi-eye-fill"></i></a>
                                        <a asp-action="Edit"    asp-route-id="@dl.Id" class="action-btn edit" title="Edit"><i class="bi bi-pencil-fill"></i></a>
                                        <a asp-action="Delete"  asp-route-id="@dl.Id" class="action-btn delete" title="Delete"><i class="bi bi-trash-fill"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
