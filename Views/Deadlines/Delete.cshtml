@model InternHub.Models.Deadline
@{
    ViewData["Title"] = "Delete Deadline";
}

<div class="container-fluid px-4">
    <div class="page-header mb-4" style="background:none; border:none; padding:1.5rem 0 0;">
        <h1><i class="bi bi-trash me-2" style="color:var(--danger);"></i>Delete Deadline</h1>
    </div>

    <div class="delete-card">
        <div class="delete-header">
            <div style="font-size:2rem; margin-bottom:0.5rem;">⚠️</div>
            <h5 class="mb-1">Are you sure?</h5>
            <small style="opacity:0.8;">This will permanently delete this deadline record.</small>
        </div>
        <div class="p-4">
            <div class="detail-field">
                <div class="detail-field-label">Title</div>
                <div class="detail-field-value">@Model.Title</div>
            </div>
            <div class="detail-field">
                <div class="detail-field-label">Due Date</div>
                <div class="detail-field-value">@Model.DueDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="detail-field">
                <div class="detail-field-label">Priority</div>
                <div class="detail-field-value">@Model.Priority</div>
            </div>

            <hr class="section-divider" />
            <div class="d-flex gap-2 justify-content-end">
                <a asp-action="Index" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Cancel</a>
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn-danger-custom">
                        <i class="bi bi-trash-fill"></i> Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
