@{
    ViewData["Title"] = "Error";
}

<div class="container-fluid px-4 mt-5 text-center">
    <div style="max-width:500px; margin:0 auto;">
        <div style="font-size:4rem; margin-bottom:1rem;">⚠️</div>
        <h1 style="color:var(--danger);">Oops! Something went wrong.</h1>
        <p style="color:var(--text-muted);">An unexpected error occurred. Please try again.</p>
        <a asp-controller="Home" asp-action="Index" class="btn-primary-custom mt-3">
            <i class="bi bi-house-fill"></i> Back to Dashboard
        </a>
    </div>
</div>
